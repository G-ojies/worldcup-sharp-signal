# ─────────────────────────────────────────────────────────────
# TxLINE API (TxODDS)  —  https://txline.txodds.com/documentation/quickstart
# ─────────────────────────────────────────────────────────────
# Base origin. Devnet: https://txline-dev.txodds.com  | Mainnet: https://txline.txodds.com
TXLINE_ORIGIN=https://txline.txodds.com

# Guest JWT from POST /auth/guest/start (short-lived; the client will auto-fetch
# one if left blank, but you can pin a known-good token here for testing).
TXLINE_JWT=

# Long-lived API token from POST /api/token/activate (after on-chain subscription
# to the free World Cup tier). REQUIRED for real data.
TXLINE_API_TOKEN=

# ─────────────────────────────────────────────────────────────
# Feed source
# ─────────────────────────────────────────────────────────────
# "live"   -> stream real StablePrice odds over SSE (needs the token above)
# "replay" -> replay a finished fixture's REAL recorded odds (needs token)
# "mock"   -> deterministic synthetic feed; runs with ZERO credentials.
SHARP_FEED=mock

# Comma-separated fixtureIds to follow in live mode (leave blank to auto-discover
# in-play World Cup fixtures from /api/fixtures/snapshot).
SHARP_FIXTURES=

# Replay mode: which finished fixture to replay, and inter-tick delay (ms).
SHARP_REPLAY_FIXTURE=18179552
SHARP_REPLAY_DELAY_MS=25

# ─────────────────────────────────────────────────────────────
# Verify-before-trade
# ─────────────────────────────────────────────────────────────
# Call the on-chain validate_odds instruction (false = skip chain hop).
SHARP_VERIFY_ONCHAIN=true
# "strict"  -> drop any signal not confirmed on-chain (production/mainnet).
# "advisory"-> open but flag signals whose odds root isn't anchored yet (devnet).
SHARP_VERIFY_POLICY=advisory

# ─────────────────────────────────────────────────────────────
# Solana settlement (devnet)  —  filled in during the on-chain milestone
# ─────────────────────────────────────────────────────────────
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Path to the agent's keypair JSON used to sign settlement txs.
AGENT_KEYPAIR_PATH=
# Deployed sharp-signal program id (devnet).
SHARP_PROGRAM_ID=

# ─────────────────────────────────────────────────────────────
# Detector tuning (safe defaults; see src/signal/detector.ts for the math)
# ─────────────────────────────────────────────────────────────
# Rolling window length (number of updates) used to estimate baseline volatility.
SHARP_WINDOW=30
# Z-score threshold above which a probability move is flagged "sharp".
SHARP_Z_THRESHOLD=3.0
# Minimum absolute implied-probability move (percentage points) to consider at all.
SHARP_MIN_MOVE_PP=1.5
# Paper stake per signal (abstract units).
SHARP_STAKE=100
